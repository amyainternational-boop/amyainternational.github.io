<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Portfolio</title>
<style>
    /* General styles */
    body {
        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
        background-color: #f8f8f8;
        margin: 0;
        padding: 0;
        color: #333;
    }

    h1 {
        text-align: center;
        margin: 2rem 0;
        font-weight: 300;
        color: #444;
    }

    /* Portfolio container */
    .portfolio {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* Individual panels */
    .panel {
        background-color: #fff;
        border-radius: 15px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
    }

    .panel:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 25px rgba(0,0,0,0.15);
    }

    .panel img {
        width: 100%;
        display: block;
        transition: transform 0.3s ease;
        border-bottom: 1px solid #eee;
    }

    .panel:hover img {
        transform: scale(1.05);
    }

    .panel h2 {
        font-size: 1.2rem;
        margin: 1rem;
        color: #555;
        font-weight: 400;
    }

    .panel p {
        font-size: 0.95rem;
        margin: 0 1rem 1rem 1rem;
        color: #777;
    }

    /* Responsive */
    @media (max-width: 600px) {
        .portfolio {
            grid-template-columns: 1fr;
            padding: 1rem;
        }
    }
</style>
</head>
<body>

<h1>My Portfolio</h1>

<div class="portfolio">
    <a href="https://via.placeholder.com/600" class="panel" target="_blank">
        <img src="https://via.placeholder.com/600" alt="Project 1">
        <h2>Project One</h2>
        <p>Short description about Project One. Clean, aesthetic, and modern.</p>
    </a>

    <a href="https://via.placeholder.com/600" class="panel" target="_blank">
        <img src="https://via.placeholder.com/600" alt="Project 2">
        <h2>Project Two</h2>
        <p>Short description about Project Two. Minimal and soft panel design.</p>
    </a>

    <a href="https://via.placeholder.com/600" class="panel" target="_blank">
        <img src="https://via.placeholder.com/600" alt="Project 3">
        <h2>Project Three</h2>
        <p>Short description about Project Three. Hover effect lifts the panel.</p>
    </a>

    <a href="https://via.placeholder.com/600" class="panel" target="_blank">
        <img src="https://via.placeholder.com/600" alt="Project 4">
        <h2>Project Four</h2>
        <p>Short description about Project Four. Soft, elegant aesthetic.</p>
    </a>
</div>

</body>
</html>
